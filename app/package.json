{
  "name": "frontend",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:swa": "swa start http://localhost:5173 --api-location api",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "generate-assets": "node scripts/generate-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@catppuccin/palette": "^1.8.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@sanity/client": "^7.22.1",
    "@tiptap/extension-code-block-lowlight": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "lowlight": "^3.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.9",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.0",
    "busboy": "^1.6.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "sharp": "^0.35.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "overrides": {
    "cookie": "^1.0.0",
    "tmp": "^0.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
